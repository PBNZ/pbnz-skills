# Normalise line endings across platforms.
* text=auto eol=lf

# Explicitly treat these as text with LF endings.
*.md        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.txt       text eol=lf
LICENSE     text eol=lf

# Common binaries.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.pdf       binary
*.zip       binary
